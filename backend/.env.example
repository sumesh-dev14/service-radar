# Copy to .env and fill in values (never commit .env)

NODE_ENV=development
PORT=5000

# MongoDB Atlas or local
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/service-radar?retryWrites=true&w=majority

# Auth — use a long random string in production (e.g. openssl rand -base64 48)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Comma-separated browser origins allowed to call the API (CORS)
# Production example: https://your-app.vercel.app,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Set to 1 when running behind nginx, Render, Railway, Fly, etc. (correct client IP / secure cookies)
# TRUST_PROXY=1

# Optional: force IPv4 for Atlas TLS issues (default: IPv4 preferred in code)
# MONGO_DISABLE_IPV4=1
