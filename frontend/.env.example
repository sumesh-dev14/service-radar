# Local development — Vite proxies /api to the backend (see vite.config.ts).
# For production build, set the public API URL (must match backend CORS ALLOWED_ORIGINS).

# Production example (no trailing slash, includes /api):
# VITE_API_URL=https://api.yourdomain.com/api

VITE_API_URL=http://localhost:5000/api

# Optional: override proxy target when running npm run dev
# VITE_DEV_API_ORIGIN=http://localhost:8000
